# Приватный ключ кошелька для деплоя в тестовые/основные сети (Sepolia, Amoy и т.д.)
PRIVATE_KEY=your_private_key_here

# RPC URL для подключения к тестовой сети Ethereum (Sepolia) (например, через Infura или Alchemy)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# RPC URL для подключения к тестовой сети Polygon (Amoy)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# API ключи для верификации исходного кода смарт-контрактов в обозревателях блоков
ETHERSCAN_API_KEY=your_etherscan_key
POLYGONSCAN_API_KEY=your_polygonscan_key
